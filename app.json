{
  "expo": {
    "name": "dating-blog",
    "slug": "dating-blog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sunflower.png",
    "scheme": "datingblog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.datingblog"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sunflower.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.datingblog"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5da55912-65c1-4044-b253-9379e6bbcefe"
      }
    }
  }
}
